# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment Variables (Security - never commit actual .env file)
.env

# Firebase Configuration (Security - templates are OK, but ignore files with real keys)
# Note: google-services.json and GoogleService-Info.plist templates are included
# with placeholder values. Replace with actual config from Firebase Console for production.
# Uncomment these lines if you want to ignore the files entirely:
# android/app/google-services.json
# ios/Runner/GoogleService-Info.plist
